-- units_example.nv
-- Demonstrates unit-annotated literals and unit types

unit AU = m;
unit solMass = kg;

mission delta_v(isp: Float, m_wet: Float, m_dry: Float) → Float {
  let g = 9.80665;
  let ratio = m_wet / m_dry;
  let dv = isp * g * (ratio ^ 2.0);
  transmit("Δv calculated");
  return dv;
}

mission orbit_calculations() → Void {
  let sun_mass = 1.989e30[kg];
  let earth_orbit = 1.496e11[m];
  
  let result = delta_v(311.0, 549054.0, 25600.0);
  transmit("Done");
}

