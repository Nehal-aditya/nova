-- model_example.nv
-- Demonstrates neural network model definition

model StarClassifier {
  layer embedding(vocab=32000, dim=512)
  layer dense(units=256, activation=0)
  layer dense(units=128, activation=1)
  layer dense(units=7, activation=2)
}

mission classify(net: StarClassifier, spectrum: Float) → Float {
  transmit("Classification complete");
  return 0.0;
}

mission main() → Void {
  transmit("Model defined");
}
